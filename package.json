{
  "author": "Charles-Henri ARNOULD <charnould@beckrel.com>",
  "license": "GPL-3.0-only",
  "type": "module",
  "name": "pierre",
  "module": "app.ts",
  "scripts": {
    "start:memory": "bash utils/run.sh init_db",
    "download": "bash utils/run.sh download_db",
    "--- format ---": "",
    "format:biome": "bunx @biomejs/biome check --config-path './config/lint+format.json' --write --unsafe .",
    "format:prettier": "bunx prettier --write '**/*.md'",
    "format:css": "find ./assets -name '*.css' -exec lightningcss {} -o;",
    "format:toc": "bunx markdown-toc -i README.md",
    "format": "bun format:toc && bun format:prettier && bun format:biome",
    "--- build ---": "",
    "build:rag": "bun run utils/knowledge/1-Scrap-wikipedia.ts && bun format:prettier && bun run utils/knowledge/2-Build-knowledge.ts",
    "--- start ---": "",
    "dev:update": "bun upgrade && bun update --latest && bun install",
    "dev:build": "bun dev:update && bun format && bun test",
    "dev:start": "rm -rf telemetry && mkdir telemetry && bun start:memory && bun --watch run app.ts",
    "start": "bun start:memory && bun run app.ts"
  },
  "dependencies": {
    "@ai-sdk/openai": "^0.0.32",
    "ai": "^3.2.1",
    "date-fns": "^3.6.0",
    "hono": "^4.4.7",
    "lodash": "^4.17.21",
    "openai": "^4.52.0",
    "sqlite-vss": "^0.1.2",
    "sqlite-vss-linux-x64": "^0.1.2",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/turndown": "^5.0.4",
    "@biomejs/biome": "^1.8.2",
    "@types/bun": "^1.1.5",
    "@types/lodash": "^4.17.5",
    "lightningcss-cli": "^1.25.1",
    "llamaindex": "^0.4.0",
    "markdown-toc": "^1.2.0",
    "puppeteer": "^22.11.2",
    "turndown": "^7.2.0",
    "typescript": "^5.5.2"
  }
}
