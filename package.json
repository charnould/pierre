{
  "author": "Charles-Henri ARNOULD <charnould@pierre-ia.org>",
  "license": "AGPL-3.0-only",
  "type": "module",
  "name": "pierre",
  "module": "app.ts",
  "scripts": {
    "------------------ BUILD ------------------": "------------------",
    "app:build": "bun --env-file=.env.production run config/build:app.ts",
    "bridge:dev": "bun build --entrypoints bridge/source/App.tsx --outdir bridge/chromium --minify --target browser --watch",
    "bridge:build": "bun run config/build:bridge.ts",
    "------------------ GLOBAL ------------------": "------------------",
    "dev": "DEBUG=true bun --env-file=.env.production --watch run app.ts",
    "css": "bunx @tailwindcss/cli@latest -i assets/core/tailwind/style.css -o assets/core/dist/css/style.css --minify --watch",
    "start": "NODE_ENV=production bun --env-file=.env.production run app.ts",
    "lint": "bun run oxlint . --ignore-pattern='**/*.js' --fix --fix-suggestions",
    "format": "bunx prettier '!**/*.js' '!assets/core/dist' --write . --plugin=prettier-plugin-embed --plugin=prettier-plugin-tailwindcss --plugin=prettier-plugin-sql",
    "generate": "bun --env-file=.env.production run ./utils/knowledge/_run.ts --community ",
    "transpile": "bun build --entrypoints assets/core/scripts/*.ts --outdir assets/core/dist/js --minify --target browser --watch",
    "pierre:config": "bun test check-config",
    "pierre:version": "bun run utils/update-pierre.ts",
    "------------------ LLM EVAL + TESTS ------------------": "------------------",
    "test:e2e": "bun test e2e --timeout 60000 --env-file=.env.production --preload ./utils/setup.ts",
    "test:unit": "bun test unit --env-file=.env.production --preload ./utils/setup.ts",
    "eval:query": "bun --env-file=.env.production test eval-augment --watch --timeout 30000",
    "eval:speed": "bun --env-file=.env.production test eval-speed --watch --timeout 30000",
    "eval:output": "bun --env-file=.env.production test generate-output --watch --timeout 30000",
    "eval:reranker": "bun --env-file=.env.production test eval-reranker --watch --timeout 30000",
    "------------------ STAGING ------------------": "------------------",
    "staging:logs": "bun --env-file=.env.staging run kamal app logs",
    "staging:setup": "bun --env-file=.env.staging run kamal setup",
    "staging:deploy": "bun --env-file=.env.staging run kamal deploy",
    "staging:console": "bun --env-file=.env.staging run kamal app exec -i bash",
    "------------------ PRODUCTION ------------------": "------------------",
    "prod:logs": "bun --env-file=.env.production run kamal app logs",
    "prod:setup": "bun --env-file=.env.production run kamal setup",
    "prod:deploy": "bun --env-file=.env.production run kamal deploy",
    "prod:console": "bun --env-file=.env.production run kamal app exec -i bash"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/cerebras": "^2.0.39",
    "@ai-sdk/cohere": "^3.0.25",
    "@ai-sdk/google": "^3.0.43",
    "@ai-sdk/groq": "^3.0.29",
    "@ai-sdk/huggingface": "^1.0.37",
    "@ai-sdk/mistral": "^3.0.24",
    "@ai-sdk/openai": "^3.0.41",
    "@ai-sdk/togetherai": "^2.0.39",
    "@date-fns/tz": "^1.4.1",
    "@observablehq/plot": "^0.6.17",
    "ai": "^6.0.116",
    "arquero": "^8.0.3",
    "cron": "^4.4.0",
    "d3": "^7.9.0",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dedent": "^1.7.2",
    "dompurify": "^3.3.3",
    "hono": "^4.12.8",
    "jsdom": "^29.0.0",
    "lodash": "^4.17.23",
    "mammoth": "^1.12.0",
    "marked": "^17.0.4",
    "natural": "^8.1.1",
    "oxfmt": "^0.41.0",
    "prettier": "^3.8.1",
    "sqlite-vec": "^0.1.7",
    "sqlite-vec-darwin-arm64": "^0.1.7",
    "sqlite-vec-linux-x64": "^0.1.7",
    "stopwords-fr": "^0.3.0",
    "talisman": "^1.1.4",
    "tiktoken": "^1.0.22",
    "turndown": "^7.2.2",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "@types/bun": "^1.3.11",
    "@types/lodash": "^4.17.24",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/turndown": "^5.0.6",
    "markdown-toc": "^1.2.0",
    "oxlint": "^1.56.0",
    "pizzip": "^3.2.0",
    "prettier-plugin-embed": "^0.5.1",
    "prettier-plugin-sql": "^0.19.2",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "puppeteer": "^24.39.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-draggable": "^4.5.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3"
  },
  "prettier": {
    "singleQuote": true,
    "semi": false,
    "trailingComma": "none",
    "printWidth": 100
  }
}
