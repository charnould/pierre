{
  "author": "Charles-Henri ARNOULD <charnould@icloud.com>",
  "license": "AGPL-3.0-only",
  "type": "module",
  "name": "pierre",
  "module": "app.ts",
  "scripts": {
    "--- format ---": "",
    "format:biome": "bunx @biomejs/biome check --config-path './config/lint+format.json' --write --unsafe .",
    "format:prettier": "bunx prettier --write . --plugin=prettier-plugin-tailwindcss",
    "format:css": "find ./assets -type f -name '*.css' -exec bunx lightningcss --targets '>= 0.25%' {} -o {} \\;",
    "format:toc": "bunx markdown-toc -i README.md",
    "format": "bun format:toc && bun format:prettier && bun format:biome && bun format:css",
    "--- build ---": "",
    "build:rag": "bun run utils/knowledge/1-Scrap-wikipedia.ts && bun format:prettier && bun run utils/knowledge/2-Build-knowledge.ts",
    "build:js": "bun build --entrypoints assets/_default/scripts/*.ts --outdir assets/_default/scripts/build --minify --target browser --watch",
    "--- start ---": "",
    "dev:css": "bunx @tailwindcss/cli@next -i assets/_default/admin.css -o assets/_default/dist/admin.css --watch --minify",
    "dev:update": "bun upgrade && bun update --latest && bun install",
    "dev:build": "bun dev:update && bun format && bun test",
    "dev:start": "bun --watch run app.ts",
    "start": "bash utils/run.sh init_db && bun run app.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^0.0.33",
    "@ai-sdk/mistral": "^0.0.25",
    "@ai-sdk/openai": "^0.0.40",
    "ai": "^3.2.37",
    "date-fns": "^3.6.0",
    "hono": "^4.5.2",
    "lodash": "^4.17.21",
    "marked": "^13.0.3",
    "sqlite-vss": "^0.1.2",
    "sqlite-vss-linux-x64": "^0.1.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.8.3",
    "@types/bun": "^1.1.6",
    "@types/lodash": "^4.17.7",
    "@types/turndown": "^5.0.5",
    "lightningcss-cli": "^1.25.1",
    "llamaindex": "^0.5.11",
    "markdown-toc": "^1.2.0",
    "prettier-plugin-tailwindcss": "^0.6.5",
    "promptfoo": "^0.73.8",
    "tailwindcss": "^4.0.0-alpha.18",
    "tiktoken": "^1.0.15",
    "turndown": "^7.2.0",
    "typescript": "^5.5.4"
  }
}
